{
    "name": "delboy1978uk/dev-tools",
    "description": "Testing and quality tools",
    "license": "MIT",
    "authors": [
        {
            "name": "Derek Stephen McLean",
            "email": "delboy1978uk@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "codeception/codeception":"^5.3",
        "codeception/module-asserts": "^3.3",
        "codeception/module-doctrine": "^3.3",
        "codeception/module-phpbrowser": "^3.0",
        "codeception/module-rest": "^3.4",
        "codeception/module-webdriver": "^3.2",
        "phpro/grumphp": "^v2.19",
        "phpstan/phpstan": "^2.1",
        "league/openapi-psr7-validator": "^0.22"
    },
    "autoload":{
        "psr-4":{
            "Bone\\DevTools\\":"src/Bone/DevTools",
            "Codeception\\Module\\":"src/Codeception/Module"
        }
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": false
        }
    }
}
